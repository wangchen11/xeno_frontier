{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gradle desktop:run",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "desktop:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "gradle desktop:debug",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "desktop:debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "gradle core:compileKotlin",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "core:compileKotlin"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
