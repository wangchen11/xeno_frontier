{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Desktop via Gradle",
      "type": "node-terminal",
      "request": "launch",
      "command": ".\\gradlew.bat desktop:run",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug Desktop via Gradle",
      "type": "node-terminal",
      "request": "launch",
      "command": ".\\gradlew.bat desktop:debug",
      "cwd": "${workspaceFolder}"
    }
  ]
}
